# Copy this file to .env.local and fill in your values.
# These variables must also be set in the Vercel dashboard (Settings → Environment Variables).

# Butterbase
NEXT_PUBLIC_BUTTERBASE_URL=https://api.butterbase.ai/v1/app_w2wmfcnqn2j2
NEXT_PUBLIC_BUTTERBASE_ANON_KEY=

# Stripe (publishable key — safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# App URL (used for redirects and Stripe Connect return URLs)
# Development: http://localhost:3000
# Production:  https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# The following are backend-only secrets.
# Set them in Butterbase dashboard (edge function environment),
# NOT in Vercel — they never touch the Next.js frontend.
# ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# EBAY_APP_ID=
# EBAY_CLIENT_SECRET=
# POKEMON_TCG_API_KEY=
# JUSTTCG_API_KEY=
# YOUTUBE_API_KEY=
# EASYPOST_API_KEY=
# RESEND_API_KEY=
